<% content_for :title, "Progress — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 pb-16">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-3xl font-bold tracking-tight">Progress</h1>
    <p class="text-lg text-muted-foreground">
      Exibe um indicador do progresso de uma tarefa.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Instalação</h2>
    <p class="text-sm text-muted-foreground">
      O item
      <code class="rounded bg-muted px-1 py-0.5 text-xs">progress</code> do
      <code class="rounded bg-muted px-1 py-0.5 text-xs">registry.json</code>
      instala estes arquivos:
    </p>
    <ul class="space-y-1 text-sm">
      <% %w[
        app/components/ui_component.rb
        app/components/ui/progress_component.rb
        app/helpers/ui_helper.rb
        vendor/shadwire/shadwire.css
      ].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground">
          <%= ui_icon("file-code", size: :sm) %>
          <code><%= path %></code>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Uso</h2>
    <p class="text-sm text-muted-foreground">
      O valor é clampado em <code class="rounded bg-muted px-1 py-0.5 text-xs">0..max</code>
      no servidor. Para atualizações ao vivo, re-renderize via Turbo (Streams/Frames) —
      o componente não tem estado no cliente.
    </p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">
      Ou renderize o componente
      <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::ProgressComponent</code>
      diretamente:
    </p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Referência da API</h2>
    <p class="text-sm text-muted-foreground">
      <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_progress(**options)</code>
      encapsula
      <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::ProgressComponent.new(**options)</code>.
    </p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50">
          <tr>
            <th>Argumento</th>
            <th>Tipo</th>
            <th>Padrão</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>value</code></td>
            <td>Numeric</td>
            <td><code>0</code></td>
            <td>Progresso atual; clampado em <code>0..max</code> e exposto como <code>aria-valuenow</code>.</td>
          </tr>
          <tr>
            <td><code>max</code></td>
            <td>Numeric</td>
            <td><code>100</code></td>
            <td>Valor máximo da escala (<code>aria-valuemax</code>).</td>
          </tr>
          <tr>
            <td><code>class</code> / <code>class_name</code></td>
            <td>String</td>
            <td><code>nil</code></td>
            <td>Classes extras (largura, altura, …).</td>
          </tr>
          <tr>
            <td><code>**attrs</code></td>
            <td>Hash</td>
            <td><code>{}</code></td>
            <td>Atributos HTML livres; rotule com <code>aria: { label: }</code>.</td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
