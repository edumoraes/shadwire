<% content_for :title, "Radio Group — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 px-5 py-12">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-4xl font-bold tracking-[-0.01em] leading-[0.95]">Radio Group</h1>
    <p class="text-lg leading-snug text-muted-foreground">
      Um conjunto de opções mutuamente exclusivas, construído sobre radios nativos.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Instalação</h2>
    <p class="text-sm text-muted-foreground">
      O item
      <code class="rounded bg-muted px-1 py-0.5 text-xs">radio-group</code> do
      <code class="rounded bg-muted px-1 py-0.5 text-xs">registry.json</code>
      instala estes arquivos:
    </p>
    <ul class="space-y-1 text-sm">
      <% %w[
        app/components/ui_component.rb
        app/components/ui/radio_group_component.rb
        app/components/ui/radio_group/item_component.rb
        app/helpers/ui_helper.rb
        vendor/shadwire/shadwire.css
      ].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground">
          <%= ui_icon("file-code", size: :sm) %>
          <code><%= path %></code>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Uso</h2>
    <p class="text-sm text-muted-foreground">
      Itens com o mesmo <code class="rounded bg-muted px-1 py-0.5 text-xs">name:</code>
      formam o grupo — seleção única e navegação por setas vêm do navegador.
      Rotule o grupo com <code class="rounded bg-muted px-1 py-0.5 text-xs">aria: { label: }</code>.
    </p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">
      Ou renderize os componentes diretamente:
    </p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Composição</h2>
    <p class="text-sm text-muted-foreground">
      Cada item é um <code class="rounded bg-muted px-1 py-0.5 text-xs">&lt;input type="radio"&gt;</code>
      nativo; o <code class="rounded bg-muted px-1 py-0.5 text-xs">name:</code> é repetido por item
      porque o ViewComponent não injeta contexto do pai.
    </p>
    <%= docs_code_block(@composition) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Referência da API</h2>
    <p class="text-sm text-muted-foreground">
      <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_radio_group(**options, &block)</code> e
      <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_radio_group_item(**options)</code>
      encapsulam os componentes correspondentes.
    </p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50">
          <tr>
            <th>Componente</th>
            <th>Argumento</th>
            <th>Padrão</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>RadioGroup</code></td>
            <td><code>class</code> / <code>class_name</code>, <code>**attrs</code></td>
            <td>—</td>
            <td>Container <code>role="radiogroup"</code>; rotule com <code>aria: { label: }</code>.</td>
          </tr>
          <tr>
            <td><code>RadioGroup::Item</code></td>
            <td><code>name:</code> (obrigatório)</td>
            <td>—</td>
            <td>Nome compartilhado do grupo de radios.</td>
          </tr>
          <tr>
            <td><code>RadioGroup::Item</code></td>
            <td><code>value:</code> (obrigatório)</td>
            <td>—</td>
            <td>Valor submetido quando o item está selecionado.</td>
          </tr>
          <tr>
            <td><code>RadioGroup::Item</code></td>
            <td><code>checked</code> / <code>disabled</code></td>
            <td><code>false</code></td>
            <td>Estado inicial do input nativo.</td>
          </tr>
          <tr>
            <td><code>RadioGroup::Item</code></td>
            <td><code>**attrs</code></td>
            <td><code>{}</code></td>
            <td>Atributos HTML livres (<code>id</code>, <code>data:</code>, <code>aria:</code>, …).</td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
