<% content_for :title, "Icon — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 px-5 py-12">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-4xl font-bold tracking-[-0.01em] leading-[0.95]">Icon</h1>
    <p class="text-lg leading-snug text-muted-foreground">
      Wrapper para lucide-rails com tamanhos shadcn e semântica acessível.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Instalação</h2>
    <p class="text-sm text-muted-foreground">O item <code class="rounded bg-muted px-1 py-0.5 text-xs">icon</code> instala estes arquivos:</p>
    <ul class="space-y-1 text-sm">
      <% %w[app/components/ui_component.rb app/components/ui/icon_component.rb app/helpers/ui_helper.rb vendor/shadwire/shadwire.css].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground"><%= ui_icon("file-code", size: :sm) %><code><%= path %></code></li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Uso</h2>
    <p class="text-sm text-muted-foreground">Nomes usam kebab-case do Lucide, como <code class="rounded bg-muted px-1 py-0.5 text-xs">"chevron-down"</code>.</p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">Ou renderize <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::IconComponent</code> diretamente:</p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Referência da API</h2>
    <p class="text-sm text-muted-foreground"><code class="rounded bg-muted px-1 py-0.5 text-xs">ui_icon(name, **options)</code> encapsula <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::IconComponent.new(name, **options)</code>.</p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50"><tr><th>Argumento</th><th>Tipo</th><th>Padrão</th><th>Descrição</th></tr></thead>
        <tbody>
          <tr><td><code>name</code></td><td>String</td><td>Obrigatório</td><td>Nome do ícone Lucide em kebab-case.</td></tr>
          <tr><td><code>size</code></td><td>Symbol/String</td><td><code>:default</code></td><td><code>:sm</code>, <code>:default</code>, <code>:lg</code> ou <code>:xl</code>.</td></tr>
          <tr><td><code>label</code></td><td>String</td><td><code>nil</code></td><td>Quando presente, expõe o SVG com <code>role="img"</code> e <code>aria-label</code>.</td></tr>
          <tr><td><code>**attrs</code></td><td>Hash</td><td><code>{}</code></td><td>Atributos HTML livres para o SVG.</td></tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
