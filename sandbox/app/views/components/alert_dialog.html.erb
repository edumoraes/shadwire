<% content_for :title, "Alert Dialog — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 pb-16">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-3xl font-bold tracking-tight">Alert Dialog</h1>
    <p class="text-lg text-muted-foreground">
      Um diálogo modal que interrompe o fluxo e exige uma resposta explícita.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Instalação</h2>
    <p class="text-sm text-muted-foreground">
      O item
      <code class="rounded bg-muted px-1 py-0.5 text-xs">alert-dialog</code> do
      <code class="rounded bg-muted px-1 py-0.5 text-xs">registry.json</code>
      instala estes arquivos:
    </p>
    <ul class="space-y-1 text-sm">
      <% %w[
        app/components/ui_component.rb
        app/components/ui/alert_dialog_component.rb
        app/components/ui/alert_dialog/trigger_component.rb
        app/components/ui/alert_dialog/content_component.rb
        app/components/ui/alert_dialog/header_component.rb
        app/components/ui/alert_dialog/footer_component.rb
        app/components/ui/alert_dialog/title_component.rb
        app/components/ui/alert_dialog/description_component.rb
        app/components/ui/alert_dialog/action_component.rb
        app/components/ui/alert_dialog/cancel_component.rb
        app/components/ui/button_component.rb
        app/helpers/ui_helper.rb
        app/javascript/controllers/ui_dialog_controller.js
        vendor/shadwire/shadwire.css
      ].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground">
          <%= ui_icon("file-code", size: :sm) %>
          <code><%= path %></code>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Uso</h2>
    <p class="text-sm text-muted-foreground">
      Compartilha o controller <code class="rounded bg-muted px-1 py-0.5 text-xs">ui-dialog</code>
      do Dialog, mas com backdrop e <kbd class="rounded bg-muted px-1 text-xs">Esc</kbd> desativados
      e <code class="rounded bg-muted px-1 py-0.5 text-xs">role="alertdialog"</code>.
      <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_alert_dialog_action</code> fecha o diálogo —
      adicione a sua ação real (form, Turbo, Stimulus) ao botão.
    </p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">
      Ou renderize os componentes diretamente:
    </p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Composição</h2>
    <%= docs_code_block(@composition) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-semibold tracking-tight">Referência da API</h2>
    <p class="text-sm text-muted-foreground">
      Todas as partes aceitam <code class="rounded bg-muted px-1 py-0.5 text-xs">class</code> /
      <code class="rounded bg-muted px-1 py-0.5 text-xs">class_name</code> e
      <code class="rounded bg-muted px-1 py-0.5 text-xs">**attrs</code>.
    </p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50">
          <tr>
            <th>Componente</th>
            <th>Argumento</th>
            <th>Padrão</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>AlertDialog</code></td>
            <td>—</td>
            <td>—</td>
            <td>Sempre injeta <code>close_on_backdrop: false</code> e <code>close_on_escape: false</code>.</td>
          </tr>
          <tr>
            <td><code>AlertDialog::Trigger</code></td>
            <td><code>variant</code>, <code>size</code></td>
            <td><code>:default</code></td>
            <td>Button que abre o diálogo.</td>
          </tr>
          <tr>
            <td><code>AlertDialog::Action</code></td>
            <td><code>variant</code>, <code>size</code></td>
            <td><code>:default</code></td>
            <td>Button de confirmação; fecha o diálogo após a sua ação.</td>
          </tr>
          <tr>
            <td><code>AlertDialog::Cancel</code></td>
            <td><code>variant</code>, <code>size</code></td>
            <td><code>:outline</code></td>
            <td>Button que dispensa o diálogo.</td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
