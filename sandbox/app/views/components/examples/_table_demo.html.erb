<%= ui_table(class: "max-w-xl") do %>
  <%= ui_table_caption { "Uma lista das suas faturas recentes." } %>
  <%= ui_table_header do %>
    <%= ui_table_row do %>
      <%= ui_table_head(scope: "col", class: "w-[100px]") { "Fatura" } %>
      <%= ui_table_head(scope: "col") { "Status" } %>
      <%= ui_table_head(scope: "col") { "Método" } %>
      <%= ui_table_head(scope: "col", class: "text-right") { "Valor" } %>
    <% end %>
  <% end %>
  <%= ui_table_body do %>
    <% [
      [ "INV001", "Paga", "Pix", "R$ 250,00" ],
      [ "INV002", "Pendente", "Boleto", "R$ 150,00" ],
      [ "INV003", "Paga", "Cartão", "R$ 350,00" ],
      [ "INV004", "Cancelada", "Pix", "R$ 450,00" ]
    ].each do |invoice, status, method, amount| %>
      <%= ui_table_row do %>
        <%= ui_table_cell(class: "font-medium") { invoice } %>
        <%= ui_table_cell { status } %>
        <%= ui_table_cell { method } %>
        <%= ui_table_cell(class: "text-right") { amount } %>
      <% end %>
    <% end %>
  <% end %>
  <%= ui_table_footer do %>
    <%= ui_table_row do %>
      <%= ui_table_cell(colspan: 3) { "Total" } %>
      <%= ui_table_cell(class: "text-right") { "R$ 1.200,00" } %>
    <% end %>
  <% end %>
<% end %>
