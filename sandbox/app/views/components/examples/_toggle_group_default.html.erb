<%= ui_toggle_group(type: :multiple, variant: :outline, "aria-label": "Formatação") do %>
  <%= ui_toggle_group_item(value: "bold", variant: :outline, "aria-label": "Negrito") { ui_icon("bold") } %>
  <%= ui_toggle_group_item(value: "italic", variant: :outline, pressed: true, "aria-label": "Itálico") { ui_icon("italic") } %>
  <%= ui_toggle_group_item(value: "underline", variant: :outline, "aria-label": "Sublinhado") { ui_icon("underline") } %>
<% end %>
