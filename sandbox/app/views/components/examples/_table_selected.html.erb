<%= ui_table(class: "max-w-md") do %>
  <%= ui_table_body do %>
    <%= ui_table_row do %>
      <%= ui_table_cell { "Linha padrão" } %>
    <% end %>
    <%= ui_table_row(data: { state: "selected" }, aria: { selected: "true" }) do %>
      <%= ui_table_cell { "Linha selecionada (data-state=\"selected\")" } %>
    <% end %>
  <% end %>
<% end %>
