<%= ui_command(class: "w-80 shadow-md") do %>
  <%= ui_command_input(placeholder: "Digite um comando ou busque...") %>
  <%= ui_command_list do %>
    <%= ui_command_empty { "Nenhum resultado encontrado." } %>
    <%= ui_command_group(heading: "Sugestões") do %>
      <%= ui_command_item(value: "calendario") do %>
        <%= ui_icon("calendar") %>
        Calendário
      <% end %>
      <%= ui_command_item(value: "emoji") do %>
        <%= ui_icon("smile") %>
        Buscar emoji
      <% end %>
    <% end %>
    <%= ui_command_separator %>
    <%= ui_command_group(heading: "Configurações") do %>
      <%= ui_command_item(value: "perfil") do %>
        <%= ui_icon("user") %>
        Perfil
        <%= ui_command_shortcut { "⌘P" } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
