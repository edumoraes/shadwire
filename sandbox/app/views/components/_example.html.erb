<%# Renders one documentation example: live preview on top, highlighted source below. %>
<%# Locals: name (example partial slug), title, description. %>
<section id="example-<%= name %>" class="scroll-mt-24 space-y-3">
  <h3 class="text-lg font-bold tracking-[-0.01em]"><%= title %></h3>
  <% if local_assigns[:description].present? %>
    <p class="text-sm text-muted-foreground"><%= description %></p>
  <% end %>

  <%# The card itself must not clip: overlay examples (popover, command, menus) %>
  <%# open absolutely-positioned content that would be cut off by overflow-hidden. %>
  <%# The code block rounds/clips its own bottom corners instead. %>
  <%= ui_card do %>
    <div class="flex min-h-[140px] flex-wrap items-center justify-center gap-3 p-8">
      <%= render "components/examples/#{name}" %>
    </div>

    <%= docs_code_block(docs_example_source(name), frame: false, class_name: "border-t overflow-hidden rounded-b-xl") %>
  <% end %>
</section>
