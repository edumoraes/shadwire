<% content_for :title, "Tabs — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 px-5 py-12">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-4xl font-bold tracking-[-0.01em] leading-[0.95]">Tabs</h1>
    <p class="text-lg leading-snug text-muted-foreground">
      Camadas de conteúdo — painéis de abas — exibidas uma por vez.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Instalação</h2>
    <p class="text-sm text-muted-foreground">
      O item
      <code class="rounded bg-muted px-1 py-0.5 text-xs">tabs</code> do
      <code class="rounded bg-muted px-1 py-0.5 text-xs">registry.json</code>
      instala estes arquivos:
    </p>
    <ul class="space-y-1 text-sm">
      <% %w[
        app/components/ui_component.rb
        app/components/ui/tabs_component.rb
        app/components/ui/tabs/list_component.rb
        app/components/ui/tabs/trigger_component.rb
        app/components/ui/tabs/content_component.rb
        app/helpers/ui_helper.rb
        app/javascript/controllers/ui_tabs_controller.js
        vendor/shadwire/shadwire.css
      ].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground">
          <%= ui_icon("file-code", size: :sm) %>
          <code><%= path %></code>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Uso</h2>
    <p class="text-sm text-muted-foreground">
      O controller Stimulus implementa o padrão WAI-ARIA de tabs: roving tabindex,
      ativação automática com <kbd class="rounded bg-muted px-1 text-xs">←</kbd>/<kbd class="rounded bg-muted px-1 text-xs">→</kbd>,
      <kbd class="rounded bg-muted px-1 text-xs">Home</kbd>/<kbd class="rounded bg-muted px-1 text-xs">End</kbd>,
      e o wiring de <code class="rounded bg-muted px-1 py-0.5 text-xs">aria-controls</code>/<code class="rounded bg-muted px-1 py-0.5 text-xs">aria-labelledby</code>.
    </p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">
      Ou renderize os componentes diretamente:
    </p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Composição</h2>
    <%= docs_code_block(@composition) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Referência da API</h2>
    <p class="text-sm text-muted-foreground">
      Todas as partes aceitam <code class="rounded bg-muted px-1 py-0.5 text-xs">class</code> /
      <code class="rounded bg-muted px-1 py-0.5 text-xs">class_name</code> e
      <code class="rounded bg-muted px-1 py-0.5 text-xs">**attrs</code>.
    </p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50">
          <tr>
            <th>Componente</th>
            <th>Argumento</th>
            <th>Padrão</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>Tabs</code></td>
            <td><code>default_value</code></td>
            <td><code>nil</code></td>
            <td>Aba aberta inicialmente; sem valor, a primeira habilitada é ativada.</td>
          </tr>
          <tr>
            <td><code>Tabs::Trigger</code></td>
            <td><code>value:</code> (obrigatório)</td>
            <td>—</td>
            <td>Identificador que liga o trigger ao painel de mesmo <code>value</code>.</td>
          </tr>
          <tr>
            <td><code>Tabs::Trigger</code></td>
            <td><code>disabled</code></td>
            <td><code>false</code></td>
            <td>Remove o trigger da ativação e da navegação por teclado.</td>
          </tr>
          <tr>
            <td><code>Tabs::Content</code></td>
            <td><code>value:</code> (obrigatório)</td>
            <td>—</td>
            <td>Painel correspondente; renderiza <code>hidden</code> até ser ativado.</td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
