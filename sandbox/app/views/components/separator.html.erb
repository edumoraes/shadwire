<% content_for :title, "Separator — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 px-5 py-12">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-4xl font-bold tracking-[-0.01em] leading-[0.95]">Separator</h1>
    <p class="text-lg leading-snug text-muted-foreground">
      Divide conteúdo visualmente ou semanticamente.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Instalação</h2>
    <p class="text-sm text-muted-foreground">O item <code class="rounded bg-muted px-1 py-0.5 text-xs">separator</code> instala estes arquivos:</p>
    <ul class="space-y-1 text-sm">
      <% %w[app/components/ui_component.rb app/components/ui/separator_component.rb app/helpers/ui_helper.rb vendor/shadwire/shadwire.css].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground"><%= ui_icon("file-code", size: :sm) %><code><%= path %></code></li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Uso</h2>
    <p class="text-sm text-muted-foreground">Use o modo semântico por padrão. Passe <code class="rounded bg-muted px-1 py-0.5 text-xs">decorative: true</code> para divisores puramente visuais.</p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">Ou renderize <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::SeparatorComponent</code> diretamente:</p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Referência da API</h2>
    <p class="text-sm text-muted-foreground"><code class="rounded bg-muted px-1 py-0.5 text-xs">ui_separator(**options)</code> encapsula <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::SeparatorComponent.new(**options)</code>.</p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50"><tr><th>Argumento</th><th>Tipo</th><th>Padrão</th><th>Descrição</th></tr></thead>
        <tbody>
          <tr><td><code>orientation</code></td><td>Symbol/String</td><td><code>:horizontal</code></td><td><code>:horizontal</code> ou <code>:vertical</code>.</td></tr>
          <tr><td><code>decorative</code></td><td>Boolean</td><td><code>nil</code></td><td>Quando <code>true</code>, renderiza <code>role="none"</code> e <code>aria-hidden="true"</code>.</td></tr>
          <tr><td><code>**attrs</code></td><td>Hash</td><td><code>{}</code></td><td>Atributos HTML livres e merge de <code>data</code>/<code>aria</code>.</td></tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
