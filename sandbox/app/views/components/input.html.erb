<% content_for :title, "Input — Shadwire" %>
<% content_for :head do %>
  <%= tag.style rouge_stylesheet %>
<% end %>

<article class="mx-auto w-full max-w-3xl space-y-12 px-5 py-12">
  <header class="space-y-3">
    <%= link_to components_path, class: "inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground" do %>
      <%= ui_icon("arrow-left", size: :sm) %>
      Componentes
    <% end %>
    <h1 class="text-4xl font-bold tracking-[-0.01em] leading-[0.95]">Input</h1>
    <p class="text-lg leading-snug text-muted-foreground">
      Exibe um campo de formulário ou um componente que se parece com um campo de texto.
    </p>
  </header>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Instalação</h2>
    <p class="text-sm text-muted-foreground">
      O item
      <code class="rounded bg-muted px-1 py-0.5 text-xs">input</code> do
      <code class="rounded bg-muted px-1 py-0.5 text-xs">registry.json</code>
      instala estes arquivos:
    </p>
    <ul class="space-y-1 text-sm">
      <% %w[
        app/components/ui_component.rb
        app/components/ui/input_component.rb
        app/helpers/ui_helper.rb
        vendor/shadwire/shadwire.css
      ].each do |path| %>
        <li class="flex items-center gap-2 text-muted-foreground">
          <%= ui_icon("file-code", size: :sm) %>
          <code><%= path %></code>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Uso</h2>
    <p class="text-sm text-muted-foreground">
      Use o helper <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_input</code>
      em qualquer view. Como <code class="rounded bg-muted px-1 py-0.5 text-xs">&lt;input&gt;</code>
      é um elemento vazio, o helper não aceita bloco — todo o estado vai em atributos.
    </p>
    <%= docs_code_block(@usage_helper) %>
    <p class="text-sm text-muted-foreground">
      Ou renderize o componente
      <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::InputComponent</code>
      diretamente:
    </p>
    <%= docs_code_block(@usage_component) %>
  </section>

  <section class="space-y-8">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Exemplos</h2>
    <% @examples.each do |example| %>
      <%= render "components/example", **example %>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="border-b pb-2 text-2xl font-bold tracking-[-0.01em]">Referência da API</h2>
    <p class="text-sm text-muted-foreground">
      <code class="rounded bg-muted px-1 py-0.5 text-xs">ui_input(**options)</code>
      encapsula
      <code class="rounded bg-muted px-1 py-0.5 text-xs">Ui::InputComponent.new(**options)</code>.
    </p>
    <%= ui_card(class: "overflow-x-auto") do %>
      <table class="w-full text-left text-sm [&_td]:border-t [&_td]:p-3 [&_td]:align-top [&_th]:p-3 [&_th]:font-medium">
        <thead class="bg-muted/50">
          <tr>
            <th>Argumento</th>
            <th>Tipo</th>
            <th>Padrão</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>type</code></td>
            <td>Symbol/String</td>
            <td><code>:text</code></td>
            <td>Qualquer tipo nativo de input (<code>:email</code>, <code>:password</code>, <code>:file</code>, <code>:number</code>, …).</td>
          </tr>
          <tr>
            <td><code>class</code> / <code>class_name</code></td>
            <td>String</td>
            <td><code>nil</code></td>
            <td>Classes extras, mescladas após as classes base.</td>
          </tr>
          <tr>
            <td><code>**attrs</code></td>
            <td>Hash</td>
            <td><code>{}</code></td>
            <td>Atributos HTML livres (<code>name</code>, <code>id</code>, <code>placeholder</code>, <code>disabled</code>, <code>required</code>, <code>data:</code>, <code>aria:</code>, …).</td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </section>
</article>
