<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Shadwire" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Shadwire">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Aplica o tema salvo antes da primeira pintura para evitar flash. %>
    <script>
      (() => {
        const stored = localStorage.getItem("theme")
        const dark = stored
          ? stored === "dark"
          : window.matchMedia("(prefers-color-scheme: dark)").matches
        document.documentElement.classList.toggle("dark", dark)
      })()
    </script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-background text-foreground">
    <header class="sticky top-0 z-40 w-full border-b border-border/60 bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5">
        <%= link_to root_path, class: "flex items-center gap-2 font-semibold tracking-tight" do %>
          <%= ui_icon("box", size: :lg, class: "text-primary") %>
          <span class="text-base">Shadwire</span>
        <% end %>

        <nav aria-label="Principal" class="flex items-center gap-1 text-sm">
          <%= link_to "Início", root_path, class: "rounded-md px-3 py-2 font-medium text-muted-foreground transition-colors hover:text-foreground" %>
          <%= link_to "Componentes", components_path, class: "rounded-md px-3 py-2 font-medium text-muted-foreground transition-colors hover:text-foreground" %>
          <%= link_to "Blocks", blocks_path, class: "rounded-md px-3 py-2 font-medium text-muted-foreground transition-colors hover:text-foreground" %>
          <%= link_to "GitHub", "https://github.com/edumoraes/shadwire", target: "_blank", rel: "noopener", class: "hidden rounded-md px-3 py-2 font-medium text-muted-foreground transition-colors hover:text-foreground sm:inline-flex" %>
          <%= ui_button(size: :icon, variant: :ghost,
                        data: { controller: "theme", action: "theme#toggle" },
                        aria: { label: "Alternar tema" }) do %>
            <%= ui_icon("moon", class: "dark:hidden") %>
            <%= ui_icon("sun", class: "hidden dark:block") %>
          <% end %>
        </nav>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="border-t border-border/60 bg-muted/30">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-10 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1">
          <p class="flex items-center gap-2 font-semibold tracking-tight">
            <%= ui_icon("box", class: "text-primary") %>Shadwire
          </p>
          <p class="max-w-md text-sm text-muted-foreground">
            Componentes shadcn/ui portados para o Ruby on Rails. Código aberto que você instala e passa a possuir.
          </p>
        </div>
        <nav aria-label="Rodapé" class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-foreground">
          <%= link_to "GitHub", "https://github.com/edumoraes/shadwire", target: "_blank", rel: "noopener", class: "transition-colors hover:text-foreground" %>
          <%= link_to "shadcn/ui", "https://ui.shadcn.com", target: "_blank", rel: "noopener", class: "transition-colors hover:text-foreground" %>
          <%= link_to "Ruby on Rails", "https://rubyonrails.org", target: "_blank", rel: "noopener", class: "transition-colors hover:text-foreground" %>
          <%= link_to "ViewComponent", "https://viewcomponent.org", target: "_blank", rel: "noopener", class: "transition-colors hover:text-foreground" %>
        </nav>
      </div>
    </footer>
  </body>
</html>
