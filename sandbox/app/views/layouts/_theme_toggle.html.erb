<div class="fixed right-4 top-4 z-50">
  <%= ui_button(size: :icon, variant: :ghost,
                data: { controller: "theme", action: "theme#toggle" },
                aria: { label: "Alternar tema" }) do %>
    <%= ui_icon("moon", class: "dark:hidden") %>
