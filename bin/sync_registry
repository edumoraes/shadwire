#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "pathname"

ROOT = Pathname.new(__dir__).join("..").expand_path
REGISTRY = JSON.parse(ROOT.join("registry/registry.json").read)
SANDBOX = ROOT.join("sandbox")

unless SANDBOX.directory?
  warn "sandbox/ does not exist. Run Task 2 before syncing registry files."
  exit 1
end

def inside_directory?(path, directory)
  relative = path.relative_path_from(directory)
  relative.each_filename.first != ".."
end

# Expands a list of items to include every item named in their
# `registryDependencies` (transitively). Lets a block reference the components
# it composes instead of re-listing all of their files. Unknown names warn and
# are skipped; missing source files are caught later by the per-file check.
def expand_with_dependencies(items, items_by_name)
  resolved = []
  visited = {}
  queue = items.dup

  until queue.empty?
    item = queue.shift
    name = item.fetch("name")
    next if visited[name]

    visited[name] = true
    resolved << item

    Array(item["registryDependencies"]).each do |dep_name|
      dep = items_by_name[dep_name]
      unless dep
        warn "Unknown registry dependency #{dep_name} (required by #{name})"
        next
      end

      queue << dep unless visited[dep_name]
    end
  end

  resolved
end

items = REGISTRY.fetch("items")
items_by_name = items.to_h { |item| [item.fetch("name"), item] }

selected_items =
  if ARGV.empty?
    complete_items = []

    items.each do |item|
      missing_sources = item.fetch("files").filter_map do |file|
        source = file.fetch("source")
        source unless ROOT.join(source).file?
      end

      if missing_sources.empty?
        complete_items << item
      else
        warn "Skipping incomplete registry item #{item.fetch("name")}: missing #{missing_sources.join(", ")}"
      end
    end

    if complete_items.empty?
      puts "No complete registry items available; nothing to sync."
      exit 0
    end

    complete_items
  else
    unknown_names = ARGV.reject { |name| items_by_name.key?(name) }
    unless unknown_names.empty?
      warn "Unknown registry item#{"s" if unknown_names.length > 1}: #{unknown_names.join(", ")}"
      exit 1
    end

    ARGV.map { |name| items_by_name.fetch(name) }
  end

selected_items = expand_with_dependencies(selected_items, items_by_name)
files = selected_items.flat_map { |item| item.fetch("files") }.uniq
targets = {}
sync_files = files.map do |file|
  source = ROOT.join(file.fetch("source"))
  target = SANDBOX.join(file.fetch("target")).expand_path

  unless inside_directory?(target, SANDBOX)
    warn "Unsafe registry target: #{file.fetch("target")}"
    exit 1
  end

  previous_source = targets[target.to_s]
  if previous_source && previous_source != file.fetch("source")
    warn "Conflicting registry target: #{target.relative_path_from(SANDBOX)} maps to both #{previous_source} and #{file.fetch("source")}"
    exit 1
  end

  targets[target.to_s] = file.fetch("source")
  { source:, target: }
end

sync_files.each do |file|
  source = file.fetch(:source)
  unless source.file?
    warn "Missing registry source: #{source.relative_path_from(ROOT)}"
    exit 1
  end
end

sync_files.each do |file|
  source = file.fetch(:source)
  target = file.fetch(:target)
  FileUtils.mkdir_p(target.dirname)
  FileUtils.cp(source, target)
  puts "synced #{source.relative_path_from(ROOT)} -> #{target.relative_path_from(ROOT)}"
end
